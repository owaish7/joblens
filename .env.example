# Copy this file to `.env` and fill in your key.
# Get a free key at https://aistudio.google.com/apikey

GEMINI_API_KEY=your_key_here

# Optional: override the default models.
# If a model name errors, run `python -m src.gemini` to list the models
# your key can access, then paste a valid name here.
GEN_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# How many jobs to pull from Remotive and index (keeps the demo fast + free).
MAX_JOBS=800
